# Identify your app to Fintraffic / Digitraffic (sent as Digitraffic-User header)
FOA_APP_ID=your-name/finnish-open-agent

# HTTP behaviour
FOA_HTTP_TIMEOUT=30
FOA_CACHE_TTL=120

# Optional API keys (only for the few services that require them)
# Free key from https://data.fingrid.fi/
FINGRID_API_KEY=
# Journey planning (transport_plan_route) from https://portal-api.digitransit.fi/
DIGITRANSIT_API_KEY=
# Geocoding (places_geocode) from https://www.maanmittauslaitos.fi/rajapinnat/api-avaimen-ohje
NLS_API_KEY=

# Transport: stdio (local, default) or http (remote streamable HTTP)
FOA_TRANSPORT=stdio
FOA_HOST=127.0.0.1
FOA_PORT=8000
